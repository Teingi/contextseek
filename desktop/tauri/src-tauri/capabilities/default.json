{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability: run the bundled Python sidecar, autostart, basic window control.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:webview:allow-navigate",
    "tauri-plugin-autostart:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/contextseek-desktop-server",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            { "validator": "\\d+" }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/contextseek-desktop-server",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            { "validator": "\\d+" }
          ]
        }
      ]
    }
  ]
}
